# Archivos y directorios a ignorar en Git

# Archivos de configuración local
config/database.local.php
config/config.local.php

# Archivos de log
*.log
logs/
error.log
access.log

# Archivos temporales
tmp/
temp/
.tmp/

# Archivos de backup
*.bak
*.backup
*.old

# Archivos del sistema operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Archivos de IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Archivos de dependencias (si se agregan en el futuro)
vendor/
node_modules/
bower_components/

# Archivos de caché
cache/
.cache/

# Archivos de uploads (si se implementan)
uploads/
files/

# Archivos de instalación (después de instalar)
install.php

# Variables de entorno
.env
.env.local
.env.production
.env.development

# Archivos de sesión PHP
sess_*

# Archivos de SQLite (si se usan)
*.sqlite
*.sqlite3
*.db

# Archivos de testing
phpunit.xml
.phpunit.result.cache
tests/_output/
coverage/

# Archivos comprimidos
*.zip
*.tar.gz
*.rar
*.7z

# Archivos de documentación generada
docs/build/
docs/_build/

# Archivos de deployment
deploy.php
deploy/

# Configuraciones específicas del servidor
.htaccess.local
apache.conf
nginx.conf